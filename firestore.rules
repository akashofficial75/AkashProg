rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdminEmail() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email != null && (
        request.auth.token.email == 'akashabdullahalmahmud335500@gmail.com' ||
        request.auth.token.email == 'expertoption55555@gmail.com' ||
        request.auth.token.email == 'admin@akashprog.com' ||
        request.auth.token.email.lower() == 'akashabdullahalmahmud335500@gmail.com' ||
        request.auth.token.email.lower() == 'expertoption55555@gmail.com' ||
        request.auth.token.email.lower() == 'admin@akashprog.com'
      );
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
    
    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
    
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
    
    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
    
    match /socials/{socialId} {
      allow read: if true;
      allow write: if isAdminEmail();
    }
  }
}
